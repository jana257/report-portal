generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


enum TicketEventType {
  ticket_created
  ticket_updated
  ticket_cancelled
  ticket_purchase_rejected
}


model TicketEvent {
  id String @id @default(cuid())

  eventId String @unique

  streamId String @unique

  type TicketEventType
  occurredAt DateTime

  payload Json

  receivedAt DateTime @default(now())

  @@index([type])
  @@index([occurredAt])
}


model ShowSnapshot {
  id String @id 

  startsAt DateTime?

  eventId String?
  eventTitle String?
  eventArtist String?

  venueId String?
  venueName String?
  venueCity String?
  venueCountry String?

  updatedAt DateTime @updatedAt

  agg ShowAgg?

  @@index([eventId])
  @@index([venueId])
  @@index([startsAt])
}


model ShowAgg {
  showId String @id
  show   ShowSnapshot @relation(fields: [showId], references: [id], onDelete: Cascade)

  ticketsSold Int @default(0)

  ticketsCancelled Int @default(0)

  purchasesRejected Int @default(0)

  updatedAt DateTime @updatedAt
}


model EventAgg {
  eventId String @id 

  eventTitle  String?
  eventArtist String?

  ticketsSold Int @default(0)
  ticketsCancelled Int @default(0)
  purchasesRejected Int @default(0)

  updatedAt DateTime @updatedAt
}

model VenueAgg {
  venueId String @id 

  venueName String?
  venueCity String?

  ticketsSold Int @default(0)
  ticketsCancelled Int @default(0)
  purchasesRejected Int @default(0)

  updatedAt DateTime @updatedAt
}


model StreamCheckpoint {
  id String @id @default("ticket_events")

  streamName String @unique
  lastStreamId String

  updatedAt DateTime @updatedAt
}